# Database (provided by Railway Postgres plugin)
DATABASE_URL=

# Auth secrets (generate strong random strings for production)
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://your-app.railway.app
QR_JWT_SECRET=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM=FairPass <hello@yourdomain.com>

# Cron security (set a random string, used to authenticate cron requests)
CRON_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Penalty config
DEFAULT_PENALTY_PERCENT=20
